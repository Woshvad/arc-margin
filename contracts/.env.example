# Arc testnet RPC. Chain ID: 5042002.
ARC_RPC_URL=https://rpc.testnet.arc.network

# Required only when deploying or redeploying PolicyContract.
# Use a deployer key funded with Arc testnet USDC. Never commit real .env files.
DEPLOYER_PRIVATE_KEY=

# Circle developer-controlled wallet address authorized as the policy agent.
# Current deployed agent wallet: 0xC16dce447f17d413a2a4F1eA6C99CEA096550656
AGENT_WALLET_ADDRESS=0xC16dce447f17d413a2a4F1eA6C99CEA096550656

# Emergency/testing fallback for deployments without a Circle agent wallet.
# Keep false for the judged ArcMargin proof path.
ALLOW_TEMP_AGENT=false
TEMP_AGENT_ADDRESS=
