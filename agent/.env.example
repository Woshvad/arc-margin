# Server
PORT=3001
CORS_ORIGIN=*
AGENT_DB_PATH=./arcmargin.sqlite
CONTRACT_CALL_TIMEOUT_MS=180000

# Arc testnet. Arc uses USDC as the gas token.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app
POLICY_CONTRACT_ADDRESS=0xbA2EA3F3a28767Ed569bB0F36E3153c60d338334

# Circle developer-controlled wallet primary signing path.
# Required for real on-chain policy cycles. Keep secrets blank in this example.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_AGENT_WALLET_ID=
CIRCLE_AGENT_WALLET_ADDRESS=0xC16dce447f17d413a2a4F1eA6C99CEA096550656

# Explicit EOA fallback path. Leave disabled for the real Circle-native proof.
ALLOW_EOA_FALLBACK=false
FALLBACK_AGENT_PRIVATE_KEY=
POLICY_OWNER_PRIVATE_KEY=

# Runtime behavior.
# Autopilot writes are gated off by default for demo safety.
ENABLE_AUTOPILOT_WRITES=false
CIRCLE_BALANCE_TTL_MS=30000
AGENT_ERC8004_ID=11576

# ERC-8004 identity registration on Arc testnet.
ERC8004_IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC8004_VALIDATION_REGISTRY_ADDRESS=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
ALLOW_IDENTITY_OWNER_FALLBACK=false
AGENT_METADATA_URI=

# Optional Telegram receipt notifications. Unconfigured by default.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
