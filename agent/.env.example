# Server
PORT=3001
CORS_ORIGIN=*
AGENT_DB_PATH=./arcmargin.sqlite
CONTRACT_CALL_TIMEOUT_MS=180000

# Arc testnet
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app
POLICY_CONTRACT_ADDRESS=0xbA2EA3F3a28767Ed569bB0F36E3153c60d338334

# Circle developer-controlled wallet primary signing path
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
